# Make.com webhook URL'leri (Vercel'de CONTACT_WEBHOOK_URL / SUPPORT_WEBHOOK_URL olarak ekleyin)
CONTACT_WEBHOOK_URL=https://hook.eu1.make.com/YOUR_WEBHOOK_ID
SUPPORT_WEBHOOK_URL=https://hook.eu1.make.com/YOUR_WEBHOOK_ID

# Blog API güvenlik anahtarı (opsiyonel)
BLOG_API_KEY=

# Admin panel şifresi (varsayılan: afn2024)
ADMIN_KEY=afn2024

# Offer response API key
OFFER_RESPONSE_API_KEY=afn2024

# Vercel Redis / Upstash Redis (offer response loglari icin)
REDIS_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
